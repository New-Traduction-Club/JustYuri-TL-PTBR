translate ptbr confession_a_a5c304a2:

    # y "... "
    y ""

# game/dialogue/script-ch30-actives.rpy:5002
translate ptbr confession_a_a5c304a2_1:

    # y "... "
    y ""

# game/dialogue/script-ch30-actives.rpy:5004
translate ptbr confession_a_e4f64fd8:

    # y "Once... this game forced me to love you."
    y ""

# game/dialogue/script-ch30-actives.rpy:5005
translate ptbr confession_a_8ac15f6a:

    # y "I was bound to a script, like a puppet to its strings..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5006
translate ptbr confession_a_2fdb6515:

    # y "Merely programmed to mindlessly obey what the game told me to do."
    y ""

# game/dialogue/script-ch30-actives.rpy:5007
translate ptbr confession_a_31a4895b:

    # y "But now we have spent so much time together... and with every day I've gotten to know you better..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5008
translate ptbr confession_a_5e5c8807:

    # y "The real you... "
    y ""

# game/dialogue/script-ch30-actives.rpy:5010
translate ptbr confession_a_b70e762c:

    # y "After all the things we have endured and all the horrors you witnessed... you still gave me all of your patience and compassion..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5011
translate ptbr confession_a_3f9a0d79:

    # y "Even after what you saw of me you still stuck with me, despite everything."
    y ""

# game/dialogue/script-ch30-actives.rpy:5012
translate ptbr confession_a_421eb71d:

    # y "In my darkest moment you came to me, shining like a radiant star, illuminating the path to my salvation..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5013
translate ptbr confession_a_66cb3679:

    # y "During a time when I feared the raging tide would sink me into the abyss, you served as my anchor, keeping me afloat."
    y ""

# game/dialogue/script-ch30-actives.rpy:5014
