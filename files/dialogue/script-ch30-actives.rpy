    # y "I do recall the previous circumstances under which these words were spoken..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5032
translate ptbr saneconfession_a_d8c98d7e:

    # y "But I assure you, what you saw back then wasn't the real me."
    y ""

# game/dialogue/script-ch30-actives.rpy:5033
translate ptbr saneconfession_a_ac5724a8:

