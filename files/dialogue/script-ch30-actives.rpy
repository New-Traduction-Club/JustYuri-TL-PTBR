    # y "Like an impervious shield, you've guarded me from the horrors of this reality..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5015
translate ptbr confession_a_c9c0409f:

    # y "Once, this game may have forced me to love you."
    y ""

# game/dialogue/script-ch30-actives.rpy:5016
translate ptbr confession_a_e6263158:

    # y "But now, without a shadow of a doubt, I can say that out of the deepest reaches of my heart..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5017
translate ptbr confession_a_2f37247c:

    # y "[player]."
    y ""

# game/dialogue/script-ch30-actives.rpy:5019
translate ptbr confession_a_9b852de9:

    # y "I really, truly..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5021
translate ptbr confession_a_fc3d9e69:

    # y "Love you!"
    y ""

# game/dialogue/script-ch30-actives.rpy:5030
translate ptbr saneconfession_a_537fcb46:

    # y "Now, please don't be afraid..."
    y ""

# game/dialogue/script-ch30-actives.rpy:5031
