    # y "L-Let's just... change the subject, okay?"
    y ""

# game/dialogue/script-ch30-idles.rpy:2215
translate ptbr idle_36_invis_eb9c286d:

    # y "That is not very nice to do... [player]. Privacy is something important to everyone!"
    y ""

# game/dialogue/script-ch30-idles.rpy:2216
translate ptbr idle_36_invis_3622375e:

    # y "Some people can feel ashamed of things and that is why they never share it."
    y ""

# game/dialogue/script-ch30-idles.rpy:2217
translate ptbr idle_36_invis_a813d57c:

    # y "I don't believe you would spy on people, but still... if you ever get the chance to... well... just don't."
    y ""

# game/dialogue/script-ch30-idles.rpy:2218
translate ptbr idle_36_invis_dafa8df6:

    # y "Let's change the topic for now."
    y ""

# game/dialogue/script-ch30-idles.rpy:2225
