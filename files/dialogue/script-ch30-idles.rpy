    y ""

# game/dialogue/script-ch30-idles.rpy:3170
translate ptbr idle_46_cde61e9c:

    # y "Oh no! Forgive me! I'm so sorry! I didn't want to remind you of the horrors you went through..."
    y ""

# game/dialogue/script-ch30-idles.rpy:3171
translate ptbr idle_46_b2da3324:

    # y "Of course, we will change this topic at once..."
    y ""

# game/dialogue/script-ch30-idles.rpy:3177
translate ptbr idle_47_7b32a7bf:

    # y "You know, I've been doing a lot of thinking about what happens after you turn the game off."
    y ""

# game/dialogue/script-ch30-idles.rpy:3178
